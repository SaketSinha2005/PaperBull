# ─── PostgreSQL connection ────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=paperbull

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=8000

# ─── Market data backend (nse-node) ────────────────────────────────────────────
# Used by the server-side Intraday (MIS) auto square-off job to fetch the
# latest price for each open intraday position.
MARKET_API_BASE=http://localhost:5000

# ─── Google OAuth (Sign in with Google) ───────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must exactly match GOOGLE_CALLBACK_URL below.
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:8000/api/auth/google/callback

# URL where the Astro frontend is served (used to redirect back after Google login)
FRONTEND_URL=http://localhost:4321
