GEMINI_API_KEY=your_gemini_api_key_here
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=my-rag-project

# ─── Brandfetch Logo API ───────────────────────────────────────────────────
# Free client ID for reliable, unthrottled logo lookups (500k req/mo free).
# Get one at https://developers.brandfetch.com/register
# Served to the frontend via GET /api/config so it never needs to be
# hardcoded in the static dashboard/logos.js bundle.
BRANDFETCH_CLIENT_ID=your_brandfetch_client_id_here
