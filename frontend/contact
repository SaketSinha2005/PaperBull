      (() => {
        const motionStorageKey = "paperbull.motionPreference";
        const normalizeMotionPreference = (value) => (value === "comfort" || value === "full" ? value : "full");
        const motionPreference = (() => {
          try {
            return normalizeMotionPreference(window.localStorage.getItem(motionStorageKey));
          } catch {
            return "full";
          }
        })();

        document.documentElement.dataset.motionPreference = motionPreference;
        document.documentElement.dataset.motion = motionPreference;
        document.documentElement.dataset.js = "true";

        const isHomepage = window.location.pathname === "/" || window.location.pathname === "";
        const hasInitialHash = window.location.hash.length > 1;
        const [navigationEntry] = performance.getEntriesByType("navigation");
        const navigationType = navigationEntry?.type ?? "navigate";
        const wasInHeroReloadZone = (() => {
          try {
            return window.sessionStorage.getItem("paperbull.heroReloadWasInHeroZone") === "true";
          } catch {
            return false;
          }
        })();

        const revealInitialSectionNavigationBoot = () => {
          if (document.documentElement.dataset.initialSectionNavigation === "pending") {
            delete document.documentElement.dataset.initialSectionNavigation;
          }
          if (document.documentElement.dataset.initialSectionNavigationScrollRestoration === "manual") {
            try {
              window.history.scrollRestoration = "auto";
            } catch {
              // Ignore browsers without scrollRestoration support.
            }
            delete document.documentElement.dataset.initialSectionNavigationScrollRestoration;
          }
        };

        const revealHeroReloadBoot = () => {
          if (document.documentElement.dataset.heroReloadBoot === "pending") {
            delete document.documentElement.dataset.heroReloadBoot;
          }
          if (document.documentElement.dataset.heroReloadScrollRestoration === "manual") {
            try {
              window.history.scrollRestoration = "auto";
            } catch {
              // Ignore browsers without scrollRestoration support.
            }
            delete document.documentElement.dataset.heroReloadScrollRestoration;
          }
        };

        if (isHomepage && hasInitialHash) {
          document.documentElement.dataset.initialSectionNavigation = "pending";

          try {
            window.history.scrollRestoration = "manual";
            document.documentElement.dataset.initialSectionNavigationScrollRestoration = "manual";
          } catch {
            // Ignore browsers without scrollRestoration support.
          }

          window.addEventListener("load", () => window.setTimeout(revealInitialSectionNavigationBoot, 900), {
            once: true,
          });
          window.addEventListener("pageshow", () => window.setTimeout(revealInitialSectionNavigationBoot, 900), {
            once: true,
          });
          window.setTimeout(revealInitialSectionNavigationBoot, 2500);
          return;
        }

